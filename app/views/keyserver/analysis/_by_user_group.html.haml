- rows        = Keyserver::SoftwareUsageByUserGroup.order(:product, :user_group)
- products    = rows.map(&:product).uniq.sort
- user_groups = rows.map(&:user_group).uniq.sort_by { |g| g.nil? ? "" : g }
- pivot       = rows.each_with_object({}) do |row, h|
  - h[row.product] ||= {}
  - h[row.product][row.user_group] = row.checkouts
- end

%p
  Checkout counts on non-staff computers, broken down by Alma user group
  (e.g. undergraduate, graduate, faculty).
  %em Unresolved
  denotes users whose login is not a PennKey.
  = link_to "← Usage profile", keyserver_software_usage_path

- if products.empty?
  %p No data available.
- else
  %table.statistics_summary
    %thead
      %tr
        %th Product
        - user_groups.each do |ug|
          %th= ug.present? ? ug : "Unresolved"
    %tbody
      - products.each do |product|
        %tr
          %td= product
          - user_groups.each do |ug|
            %td= number_with_delimiter(pivot.dig(product, ug))
