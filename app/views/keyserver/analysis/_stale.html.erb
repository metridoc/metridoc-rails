<% profiles = Keyserver::SoftwareUsageProfile.non_active.order(days_since_checkout: :desc) %>

<p>Products with no checkout in 90+ days, sorted by most dormant first.
   <%= link_to "&larr; All products".html_safe, keyserver_software_usage_path %></p>

<% if profiles.empty? %>
  <p>No stale or dormant products found.</p>
<% else %>
  <table class="statistics_summary">
    <thead>
      <tr>
        <th>Product</th>
        <th>Status</th>
        <th>Last Checkout</th>
        <th>Days Since Checkout</th>
        <th>Total Checkouts</th>
        <th>Distinct Users</th>
      </tr>
    </thead>
    <tbody>
      <% profiles.each do |p| %>
        <tr>
          <td><%= p.product %></td>
          <td><span class="ks-status <%= p.status&.downcase %>"><%= p.status %></span></td>
          <td><%= p.last_checkout&.to_date %></td>
          <td><%= p.days_since_checkout %></td>
          <td><%= number_with_delimiter(p.checkouts) %></td>
          <td><%= number_with_delimiter(p.distinct_users) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
