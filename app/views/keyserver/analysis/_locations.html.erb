<%
  by_hour    = Keyserver::LocationByHour.order(:location, :hour_of_day).group_by(&:location)
  by_dow     = Keyserver::LocationByDow.order(:location, :day_of_week).group_by(&:location)
  locations  = by_hour.keys | by_dow.keys
%>

<p>Session counts by location during business hours (8 AM – 10:59 PM).
   <%= link_to "&larr; Usage profile".html_safe, keyserver_software_usage_path %></p>

<% if locations.empty? %>
  <p>No location data available.</p>
<% else %>

  <%# Build hour pivot: hour → location → sessions -%>
  <%
    hour_pivot = {}
    all_hours  = []
    locations.each do |loc|
      (by_hour[loc] || []).each do |row|
        h = row.hour_of_day
        all_hours << h
        hour_pivot[h] ||= {}
        hour_pivot[h][loc] = row.sessions
      end
    end
    all_hours = all_hours.uniq.sort
  %>

  <h2>Sessions by Hour of Day</h2>
  <table class="statistics_summary">
    <thead>
      <tr>
        <th>Hour</th>
        <% locations.each do |loc| %><th><%= loc %></th><% end %>
      </tr>
    </thead>
    <tbody>
      <% all_hours.each do |hour| %>
        <tr>
          <td><%= "%02d:00" % hour %></td>
          <% locations.each do |loc| %>
            <td><%= number_with_delimiter(hour_pivot.dig(hour, loc)) %></td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%# Build DOW pivot: day_name → location → sessions -%>
  <%
    day_order = %w[Monday Tuesday Wednesday Thursday Friday Saturday Sunday]
    dow_pivot = {}
    all_days  = []
    locations.each do |loc|
      (by_dow[loc] || []).each do |row|
        d = row.day_name
        all_days << d
        dow_pivot[d] ||= {}
        dow_pivot[d][loc] = row.sessions
      end
    end
    all_days = day_order & all_days.uniq
  %>

  <h2>Sessions by Day of Week</h2>
  <table class="statistics_summary">
    <thead>
      <tr>
        <th>Day</th>
        <% locations.each do |loc| %><th><%= loc %></th><% end %>
      </tr>
    </thead>
    <tbody>
      <% all_days.each do |day| %>
        <tr>
          <td><%= day %></td>
          <% locations.each do |loc| %>
            <td><%= number_with_delimiter(dow_pivot.dig(day, loc)) %></td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>

<% end %>
