<h1>Software Usage by User Group</h1>
<p>Checkout counts on non-staff computers, broken down by Alma user group
   (e.g. undergraduate, graduate, faculty).
   <em>Unresolved</em> denotes users whose login is not a PennKey.
   <%= link_to "&larr; Usage profile".html_safe, keyserver_root_path %></p>

<% if @products.empty? %>
  <p>No data available.</p>
<% else %>
  <table class="statistics_summary">
    <thead>
      <tr>
        <th>Product</th>
        <% @user_groups.each do |ug| %>
          <th><%= ug.present? ? ug : "Unresolved" %></th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% @products.each do |product| %>
        <tr>
          <td><%= product %></td>
          <% @user_groups.each do |ug| %>
            <td><%= number_with_delimiter(@pivot.dig(product, ug)) %></td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
