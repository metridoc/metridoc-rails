<%
  rows        = Keyserver::SoftwareUsageByUserGroup.order(:product, :user_group)
  products    = rows.map(&:product).uniq.sort
  user_groups = rows.map(&:user_group).uniq.sort_by { |g| g.nil? ? "" : g }
  pivot       = rows.each_with_object({}) do |row, h|
                  h[row.product] ||= {}
                  h[row.product][row.user_group] = row.checkouts
                end
%>

<p>Checkout counts on non-staff computers, broken down by Alma user group
   (e.g. undergraduate, graduate, faculty).
   <em>Unresolved</em> denotes users whose login is not a PennKey.
   <%= link_to "&larr; Usage profile".html_safe, keyserver_software_usage_path %></p>

<% if products.empty? %>
  <p>No data available.</p>
<% else %>
  <table class="statistics_summary">
    <thead>
      <tr>
        <th>Product</th>
        <% user_groups.each do |ug| %>
          <th><%= ug.present? ? ug : "Unresolved" %></th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% products.each do |product| %>
        <tr>
          <td><%= product %></td>
          <% user_groups.each do |ug| %>
            <td><%= number_with_delimiter(pivot.dig(product, ug)) %></td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
